{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blackcell.dev/schemas/change-spec-v1.json",
  "title": "BlackCell Change Spec v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "work_id",
    "objective",
    "base_sha",
    "acceptance_criteria",
    "in_scope",
    "out_of_scope",
    "constraints",
    "assumptions",
    "unknowns"
  ],
  "properties": {
    "schema_version": {
      "const": "blackcell-change-spec/v1"
    },
    "work_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
    },
    "objective": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "base_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40,64}$"
    },
    "acceptance_criteria": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "in_scope": {
      "type": "array",
      "maxItems": 200,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      }
    },
    "out_of_scope": {
      "type": "array",
      "maxItems": 200,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      }
    },
    "constraints": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "assumptions": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "unknowns": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    }
  }
}
